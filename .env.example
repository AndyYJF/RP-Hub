# RP-Hub 环境变量示例（Docker Compose 用）
# 复制为 .env 并修改其中的密钥与初始管理员密码
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeOnFirstLogin!
ALLOW_REGISTER=true
CORS_ORIGIN=*

# 可选：限制代理可访问的上游主机（逗号分隔，如 api.openai.com,api.example.com）
# 留空则仅阻止内网/本地地址，允许公网主机
# PROXY_ALLOWED_HOSTS=

# 设为 false 可关闭 CSP（调试 HTML 卡片 / CDN 问题时使用）
# CONTENT_SECURITY_POLICY=false
