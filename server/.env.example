# 服务端口
PORT=3000

# JWT 密钥（请务必修改为随机长字符串）
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too-also-long-random

# Access Token 有效期（如 15m / 2h）
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# 管理员初始化账号（首次启动 init-admin 脚本时使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-immediately

# 是否允许自由注册（false 时只能由管理员后台创建账号）
ALLOW_REGISTER=true

# 数据库文件路径
DB_PATH=./data/rphub.db

# 前端静态文件目录（用于 Docker 部署时由后端直接托管前端）
# 留空则不托管，前端需独立部署或由 Nginx 反代
STATIC_DIR=

# CORS 允许来源（逗号分隔，* 表示全部）
CORS_ORIGIN=*

# 可选：限制代理可访问的上游主机（逗号分隔）
# PROXY_ALLOWED_HOSTS=api.openai.com,api.example.com
